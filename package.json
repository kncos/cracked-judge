{
  "name": "crackedjudge",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "bun run build:host;bun run build:guest",
    "build:host": "bun build --target=bun --outfile=./vmroot/base/host.js src/host.ts",
    "build:guest": "bun build --target=bun --outfile=./mkosi/mkosi.extra/app/guest.js src/guest.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@types/eslint": "^9.6.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "openapi-fetch": "^0.17.0",
    "typescript-eslint": "^8.57.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@orpc/client": "^1.13.6",
    "@orpc/server": "^1.13.6",
    "hono": "^4.12.8",
    "ioredis": "^5.10.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  }
}

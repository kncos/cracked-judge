{
  "boot-source": {
    "kernel_image_path": "vmlinux-6.1.163",
    "boot_args": "console=ttyS0 reboot=k panic=1 pci=off nomodule root=/dev/vda rw init=/sbin/busybox init"
  },
  "drives": [
    {
      "drive_id": "rootfs",
      "path_on_host": "rootfs.ext4",
      "is_root_device": true,
      "is_read_only": false
    }
  ],
  "machine-config": {
    "vcpu_count": 1,
    "mem_size_mib": 1024
  },
  "logger": {
    "log_path": "/tmp/fc.log",
    "level": "Debug",
    "show_level": true,
    "show_log_origin": true
  },
  "metrics": {
    "metrics_path": "/tmp/fc-metrics.fifo"
  },
  "network-interfaces": [
    {
      "iface_id": "eth0",
      "guest_mac": "AA:FC:00:00:00:01",
      "host_dev_name": "tap0"
    }
  ]
}

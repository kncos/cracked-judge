# Kernel
KERNEL_ARCH="x86_64"
KERNEL_VERSION="6.1.163"
KERNEL_S3_BASE="https://s3.amazonaws.com/spec.ccfc.min/firecracker-ci-custom/jxcurtis-new-ci-build-0"
KERNEL_URL="${KERNEL_S3_BASE}/${KERNEL_ARCH}/vmlinux-${KERNEL_VERSION}"

# Image defaults
ROOTFS_SIZE_MB=4096
ROOTFS_FORMAT=ext4

# VM defaults
VM_VCPUS=2
VM_MEM_MB=1024
FC_SOCKET="/tmp/firecracker.sock"

# Networking (inside guest)
GUEST_IP="172.16.0.2"
GUEST_GW="172.16.0.1"
GUEST_DNS="8.8.8.8"
HOST_TAP_IP="172.16.0.1"
HOST_TAP_DEV="tap0"
{
  "name": "cracked-judge",
  "type": "module",
  "private": true,
  "scripts": {
    "postinstall": "bun2nix -o ../nix/bun.nix -c ../cracked-judge/",
    "build": "bun run build:host;bun run build:guest",
    "build:host": "bun build --target=bun --outfile=host.js src/host.ts",
    "build:guest": "bun build --compile --minify --sourcemap src/guest/index.ts --outfile guest/runtime/guest-bin",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:guest": "bun test apps/guest"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@types/eslint": "^9.6.1",
    "@types/node": "^25.5.0",
    "bun-types": "^1.3.12",
    "bun2nix": "^2.0.8",
    "eslint": "^10.0.3",
    "openapi-fetch": "^0.17.0",
    "typescript-eslint": "^8.57.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@orpc/client": "^1.13.6",
    "@orpc/server": "^1.13.6",
    "generic-pool": "^3.9.0",
    "ioredis": "^5.10.0",
    "msgpackr": "^1.11.9",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "workspaces": [
    "apps/*",
    "common"
  ]
}

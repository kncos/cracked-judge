#!/bin/sh

mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t cgroup2 cgroup2 /sys/fs/cgroup
mount -t devtmpfs devtmpfs /dev
mount -t tmpfs tmpfs /tmp

# cgroup setup for isolate
echo "+cpuset +memory" > /sys/fs/cgroup/cgroup.subtree_control
mkdir -p /sys/fs/cgroup/isolate
echo "+cpuset +memory" > /sys/fs/cgroup/isolate/cgroup.subtree_control
mkdir -p /run/isolate/locks

export PATH=/usr/local/bin:$PATH

# fix isolate environment
isolate-check-environment -e &>/dev/null || true
echo ">>> ISOLATE ENVIRONMENT CHECK"
if ! isolate-check-environment; then
  echo ">>> ISOLATE ENVIRONMENT FAILED CHECK"
else
  echo ">>> ISOLATE ENVIRONMENT PASSES CHECK"
fi

# networking
ip link set lo up
ip addr add 127.0.0.1/8 dev lo
# socat TCP-LISTEN:3000,fork,reuseaddr VSOCK-CONNECT:2:52

/bin/busybox hostname judge-vm

echo ">>> running local network tests"
# 1. Check if loopback interface exists and its state
ip link show lo
# 2. Check if it's actually up
ip addr show lo
# 3. Check if you can ping yourself
ping -c 3 -W 1 127.0.0.1
# 4. List all network interfaces so we can see what exists
ip link show
# 5. Check if socat is actually running at all
ps aux | grep socat
# 6. Try to connect to port 3000 directly with a raw tool
nc -zv localhost 3000 2>&1 || echo "nc failed"
